DATABASE_URL="postgresql://your-user:your-password@localhost:5432/make_santa_fe_crm?schema=public"
DATABASE_CA_CERT=""
WORDPRESS_BASE_URL="https://your-wordpress-site.example.org"
WORDPRESS_CRM_BRIDGE_TOKEN="replace-with-your-bridge-token"
WORDPRESS_SYNC_PAGE_SIZE="100"
WORDPRESS_SYNC_REQUEST_DELAY_MS="300"
WORDPRESS_SYNC_RETRY_COUNT="4"
WORDPRESS_SYNC_RETRY_DELAY_MS="1500"
CRM_SESSION_SECRET="replace-with-a-long-random-secret"
CRM_APP_BASE_URL="https://crm.your-domain.example.org"
CRM_SYNC_FRESHNESS_SECONDS="300"
ALLOW_DEV_LOGIN="true"
